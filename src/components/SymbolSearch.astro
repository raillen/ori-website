---
/** Global symbol search (⌘K / Ctrl+K) over symbols.json */
---

<button type="button" class="ori-search-trigger sl-hidden md:sl-flex" id="ori-search-open" aria-label="Search symbols">
  Search symbols <kbd>⌘K</kbd>
</button>

<div class="ori-search-dialog" id="ori-search-dialog" role="dialog" aria-modal="true" aria-label="Symbol search" data-open="false">
  <div class="ori-search-panel">
    <input
      type="search"
      class="ori-search-input"
      id="ori-search-input"
      placeholder="Functions, modules, errors, keywords…"
      autocomplete="off"
      spellcheck="false"
    />
    <ul class="ori-search-results" id="ori-search-results" role="listbox"></ul>
  </div>
</div>

<script>
  import MiniSearch from "minisearch";

  const dialog = document.getElementById("ori-search-dialog");
  const input = document.getElementById("ori-search-input");
  const resultsEl = document.getElementById("ori-search-results");
  const openBtn = document.getElementById("ori-search-open");

  let mini = null;
  let items = [];

  async function loadIndex() {
    const res = await fetch("/symbols.json");
    const data = await res.json();
    items = [];

    for (const s of data.symbols) {
      items.push({
        id: s.id,
        kind: "function",
        module: s.module,
        text: `${s.id} ${s.name} ${s.signature} ${s.module}`,
        signature: s.signature,
        layer: s.layer,
        href: `/reference/stdlib/${s.module.replace(/\./g, "-").toLowerCase()}/#${s.id.replace(/\./g, "-")}`,
      });
    }
    for (const e of data.errors) {
      items.push({
        id: e.code,
        kind: "error",
        text: `${e.code} ${e.summary}`,
        signature: e.summary,
        href: "/reference/errors/#" + e.code.replace(/\./g, "-"),
      });
    }
    for (const k of data.keywords) {
      items.push({
        id: k,
        kind: "keyword",
        text: k,
        signature: "Ori keyword",
        href: "/language/types/",
      });
    }

    mini = new MiniSearch({
      fields: ["id", "text", "module"],
      storeFields: ["id", "kind", "signature", "href", "layer"],
    });
    mini.addAll(items);
  }

  function renderResults(hits) {
    resultsEl.innerHTML = "";
    for (const hit of hits.slice(0, 20)) {
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = hit.href;
      a.innerHTML = `
        <div class="ori-search-kind">${hit.kind}${hit.layer ? `<span class="ori-layer-badge">${hit.layer}</span>` : ""}</div>
        <div class="ori-search-id">${hit.id}</div>
        <div class="ori-search-sig">${hit.signature ?? ""}</div>
      `;
      li.appendChild(a);
      resultsEl.appendChild(li);
    }
  }

  function openSearch() {
    dialog?.setAttribute("data-open", "true");
    input?.focus();
    if (!mini) loadIndex().then(() => input?.select());
  }

  function closeSearch() {
    dialog?.setAttribute("data-open", "false");
    if (input) input.value = "";
    resultsEl.innerHTML = "";
  }

  openBtn?.addEventListener("click", openSearch);

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openSearch();
    }
    if (e.key === "Escape") closeSearch();
  });

  dialog?.addEventListener("click", (e) => {
    if (e.target === dialog) closeSearch();
  });

  input?.addEventListener("input", () => {
    if (!mini) return;
    const q = input.value.trim();
    if (!q) {
      resultsEl.innerHTML = "";
      return;
    }
    const hits = mini.search(q, { prefix: true, fuzzy: 0.15 });
    renderResults(hits);
  });

  loadIndex();
</script>

<style>
  kbd {
    font-family: var(--sl-font-mono);
    font-size: 0.75rem;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    border: 1px solid var(--sl-color-gray-5);
    margin-left: 0.35rem;
  }
  @media (max-width: 768px) {
    .ori-search-trigger {
      display: none !important;
    }
  }
</style>
